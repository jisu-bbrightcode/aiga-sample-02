{
  "name": "@aiga/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Aiga Sample 02 — backend server (Content Catalog and future feature modules)",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"test/**/*.test.ts\"",
    "test:auth-membership": "node --import tsx --test \"test/auth-membership/**/*.test.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "pg": "^8.13.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.28.1",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
