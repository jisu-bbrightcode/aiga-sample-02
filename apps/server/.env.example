# Aiga server environment
# Copy to .env and fill in values. See src/config/env.ts for the full contract.

# HTTP
PORT=3001
NODE_ENV=development

# Persistence backend: "memory" (default, no DB) or "postgres"
CONTENT_STORE=memory

# Neon / PostgreSQL connection (required when CONTENT_STORE=postgres)
DATABASE_URL=

# Auth (provisional — integrates with BBR-1121 Auth & 3-tier Membership).
# Shared HS256 secret used to verify bearer JWTs issued by the auth service.
AUTH_JWT_SECRET=dev-only-insecure-secret-change-me
# When true, an unsigned "x-debug-user" header may be used in non-production for local testing.
AUTH_ALLOW_DEBUG_HEADER=true
