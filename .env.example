# =============================================================================
# Aiga Sample 02 — environment variable mapping (BBR-1117 Core Infra)
# Copy to .env (local) and configure the same keys in Vercel project settings.
# =============================================================================

# --- Database: Neon (PostgreSQL) --------------------------------------------
# Pooled connection (serverless / app runtime). Use the -pooler host from Neon.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/aiga?sslmode=require"
# Direct (unpooled) connection — required by drizzle-kit for migrations.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/aiga?sslmode=require"

# --- Auth: better-auth ------------------------------------------------------
# 32+ char random secret. Generate: openssl rand -base64 32
BETTER_AUTH_SECRET="change-me-in-production"
# Canonical URL of the auth/server origin.
BETTER_AUTH_URL="http://localhost:8787"

# --- Server (apps/server) ---------------------------------------------------
PORT="8787"
NODE_ENV="development"
# Comma-separated allowed browser origins (app + admin).
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# --- Public app (apps/app) --------------------------------------------------
NEXT_PUBLIC_API_BASE_URL="http://localhost:8787"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin app (apps/admin) -------------------------------------------------
NEXT_PUBLIC_ADMIN_API_BASE_URL="http://localhost:8787"
NEXT_PUBLIC_ADMIN_URL="http://localhost:3001"
